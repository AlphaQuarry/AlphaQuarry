# Core datasource overrides
PROJECT_LAKE_ROOT=data/lake
PROJECT_DUCKDB_PATH=data/duckdb/market.duckdb
PROJECT_SOURCE_VIEW=v_project_panel_cn_a
PROJECT_SOURCE_BACKEND=duckdb
PROJECT_ADJUST_MODE=qfq
PROJECT_FIELD_CATALOG_VERSION=v1

# Optional run filters (JSON object string)
PROJECT_RUN_FILTERS_JSON={"universe_only": true, "include_bj": true}

# Universe/tradability defaults
PROJECT_INCLUDE_BJ=true
PROJECT_UNIVERSE_EXCLUDE_ST=true
PROJECT_UNIVERSE_MIN_DAYS_SINCE_LISTED=60
PROJECT_UPDATE_LOOKBACK_TRADE_DAYS=5

# Tushare credentials
TUSHARE_TOKEN=
TUSHARE_HTTP_URL=
TUSHARE_MAX_RETRIES=3
TUSHARE_RETRY_SLEEP_SECONDS=1.5
TUSHARE_REQUEST_PAUSE_SECONDS=0.0
